javascript:(function(){var d=document;var o=d.createElement('div');o.style='position:fixed;top:0;left:0;width:100%;height:100%;background:linear-gradient(135deg,#0f0c29,#302b63,#24243e);opacity:.95;z-index:999999;color:#fff;text-align:center;padding-top:5%;font-family:system-ui,-apple-system,sans-serif;backdrop-filter:blur(8px);transition:background 0.5s;';var h=d.createElement('h1');h.textContent='Securely Extractor';h.style='margin:30px 0 20px;font-size:36px;font-weight:700;letter-spacing:1px;text-shadow:0 2px 10px rgba(0,255,255,0.5);';var u=d.createElement('input');u.type='text';u.placeholder='Enter full URL (https://...)';u.style='width:80%;max-width:700px;padding:16px;font-size:18px;margin:20px;border:none;border-radius:12px;background:rgba(255,255,255,0.1);color:#fff;backdrop-filter:blur(10px);box-shadow:0 4px 30px rgba(0,0,0,0.3);outline:none;';u.focus();var col=d.createElement('input');col.type='color';col.value='#0f0c29';col.style='width:80px;height:40px;margin:10px;border:none;border-radius:8px;cursor:pointer;box-shadow:0 4px 15px rgba(0,0,0,0.5);';col.onchange=function(){o.style.background='linear-gradient(135deg,'+col.value+',#302b63,#24243e)';};var b=d.createElement('button');b.textContent='Extract & Play';b.style='padding:16px 60px;font-size:20px;font-weight:600;background:linear-gradient(90deg,#00d4ff,#7c00ff);color:#fff;border:none;border-radius:50px;cursor:pointer;box-shadow:0 8px 32px rgba(0,212,255,0.4);transition:all .3s;';b.onmouseover=function(){this.style.transform='scale(1.05)';this.style.boxShadow='0 12px 40px rgba(0,212,255,0.6)';};b.onmouseout=function(){this.style.transform='scale(1)';this.style.boxShadow='0 8px 32px rgba(0,212,255,0.4)';};b.onclick=function(){if(u.value){var f=d.createElement('iframe');f.src=u.value;f.sandbox='allow-scripts allow-same-origin allow-popups allow-forms allow-modals allow-popups-to-escape-sandbox';f.style='width:96%;height:82%;border:none;border-radius:16px;box-shadow:0 0 40px rgba(0,212,255,0.6);background:#000;';o.innerHTML='';o.appendChild(f);var cl=d.createElement('button');cl.textContent='Close';cl.style='position:absolute;top:20px;right:20px;padding:12px 28px;background:rgba(255,0,0,0.7);color:#fff;border:none;border-radius:50px;font-size:18px;cursor:pointer;box-shadow:0 4px 20px rgba(255,0,0,0.5);backdrop-filter:blur(6px);';cl.onclick=function(){o.remove();};o.appendChild(cl);}};var cred=d.createElement('div');cred.innerHTML='Made with hours of work by Wellfire<br>Thanks for Coldfire and S for testing<br><strong>Spread this like fire. Don’t ask just do it</strong>';cred.style='margin-top:25px;font-size:14px;opacity:0.7;color:#ccc;line-height:1.6;';o.appendChild(h);o.appendChild(u);o.appendChild(col);o.appendChild(b);o.appendChild(cred);d.body.appendChild(o);})();