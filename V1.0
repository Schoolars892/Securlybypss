javascript:(function(){var d=document;var o=d.createElement('div');o.style='position:fixed;top:0;left:0;width:100%;height:100%;background:#000;opacity:.92;z-index:99999;color:#fff;text-align:center;padding-top:15%;font-family:Arial;';var h=d.createElement('h2');h.textContent='Securely Extractor';h.style='margin:20px;';var u=d.createElement('input');u.type='text';u.placeholder='Type full URL (https://...)';u.style='width:85%;max-width:600px;padding:12px;font-size:18px;margin:15px;border-radius:6px;border:none;';var b=d.createElement('button');b.textContent='Extract & Play';b.style='padding:14px 40px;font-size:18px;background:#2196F3;color:#fff;border:none;border-radius:6px;cursor:pointer;';b.onclick=function(){if(u.value){var f=d.createElement('iframe');f.src=u.value;f.sandbox='allow-scripts allow-same-origin allow-popups allow-forms allow-modals';f.style='width:92%;height:70%;border:none;border-radius:10px;box-shadow:0 0 20px rgba(0,255,255,0.3);';o.innerHTML='';o.appendChild(f);var cl=d.createElement('button');cl.textContent='Close';cl.style='position:absolute;top:10px;right:10px;padding:8px 16px;background:#f44336;color:#fff;border:none;border-radius:4px;cursor:pointer;';cl.onclick=function(){o.remove();};o.appendChild(cl);}};o.appendChild(h);o.appendChild(u);o.appendChild(b);d.body.appendChild(o);})();