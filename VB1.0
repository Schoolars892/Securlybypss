javascript:(function(){var d=document;var o=d.createElement('div');o.style='position:fixed;top:0;left:0;width:100%;height:100%;background:#111;opacity:.98;z-index:999999;color:#eee;font-family:Arial;overflow:auto;';var t=d.createElement('div');t.style='padding:20px;max-width:900px;margin:0 auto;';var h=d.createElement('h1');h.textContent='Web Player - Extracted Page';h.style='color:#0f0;text-align:center;';var c=d.createElement('div');c.innerHTML=d.documentElement.innerHTML.replace(/<script.*?<\/script>/gi,'').replace(/<style.*?<\/style>/gi,'').replace(/on\w+="[^"]*"/gi,'');c.style='background:#000;padding:15px;border-radius:8px;white-space:pre-wrap;word-wrap:break-word;';var b=d.createElement('div');b.style='text-align:center;margin:20px;';var p=d.createElement('button');p.textContent='Play';p.style='padding:10px 30px;font-size:18px;background:#4CAF50;color:#fff;border:none;border-radius:5px;margin:10px;cursor:pointer;';var s=d.createElement('button');s.textContent='Stop';s.style='padding:10px 30px;font-size:18px;background:#f44336;color:#fff;border:none;border-radius:5px;margin:10px;cursor:pointer;';var cl=d.createElement('button');cl.textContent='Close Player';cl.style='padding:8px 20px;font-size:14px;background:#555;color:#fff;border:none;border-radius:5px;cursor:pointer;position:absolute;top:10px;right:10px;';cl.onclick=function(){o.remove();};b.appendChild(p);b.appendChild(s);o.appendChild(cl);t.appendChild(h);t.appendChild(c);t.appendChild(b);o.appendChild(t);d.body.appendChild(o);})();