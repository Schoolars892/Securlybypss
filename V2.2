javascript:(function(){var d=document;var o=d.createElement('div');o.style='position:fixed;top:0;left:0;width:100%;height:100%;background:linear-gradient(135deg,#0f0c29,#302b63,#24243e);opacity:.95;z-index:999999;color:#fff;text-align:center;padding:5% 10%;font-family:system-ui,-apple-system,sans-serif;backdrop-filter:blur(8px);overflow:auto;';var h=d.createElement('h1');h.textContent='Securely Data Extractor';h.style='margin:0 0 25px;font-size:38px;font-weight:700;letter-spacing:1px;text-shadow:0 2px 12px rgba(0,255,255,0.6);';var u=d.createElement('input');u.type='text';u.placeholder='Enter full URL to extract (https://...)';u.style='width:85%;max-width:800px;padding:18px;font-size:20px;margin:20px;border:none;border-radius:16px;background:rgba(255,255,255,0.12);color:#fff;backdrop-filter:blur(12px);box-shadow:0 6px 35px rgba(0,0,0,0.4);outline:none;';u.focus();var b=d.createElement('button');b.textContent='Extract Data';b.style='padding:18px 70px;font-size:22px;font-weight:600;background:linear-gradient(90deg,#00d4ff,#7c00ff);color:#fff;border:none;border-radius:60px;cursor:pointer;box-shadow:0 10px 40px rgba(0,212,255,0.5);transition:all .3s;';b.onmouseover=function(){this.style.transform='scale(1.06)';this.style.boxShadow='0 15px 50px rgba(0,212,255,0.7)';};b.onmouseout=function(){this.style.transform='scale(1)';this.style.boxShadow='0 10px 40px rgba(0,212,255,0.5)';};var status=d.createElement('div');status.textContent='Waiting...';status.style='margin:20px;font-size:18px;color:#0f0;';var cred=d.createElement('div');cred.innerHTML='Made with hours of work by Wellfire<br>Thanks for Coldfire and S for testing<br><strong>Spread this like fire. Don’t ask just do it</strong>';cred.style='margin-top:30px;font-size:15px;opacity:0.75;color:#ccc;line-height:1.6;';b.onclick=async function(){if(!u.value)return;status.textContent='Extracting...';try{var p='https://corsproxy.io/?'+encodeURIComponent(u.value);var r=await fetch(p);var t=await r.text();var clean=t.replace(/<s